# Copy to .env.local for local dev. In production, set these in your hosting
# provider (Vercel → Project → Settings → Environment Variables). Never commit
# real secret values.

# ---------------------------------------------------------------------------
# Supabase  (Dashboard → Project Settings → API)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER ONLY — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Stripe  (Dashboard → Developers → API keys)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret. Local: from `stripe listen`. Prod: from the webhook
# endpoint you create in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Legacy — only used by the admin "create subscription" action. Optional.
STRIPE_DEFAULT_PRICE_ID=price_xxx

# ---------------------------------------------------------------------------
# Email (optional) — Resend. Without a key, emails are silently skipped.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Blend Mode <onboarding@resend.dev>
# Where new-ticket notifications go (optional).
ADMIN_NOTIFY_EMAIL=

# ---------------------------------------------------------------------------
# Cron (optional) — protects /api/cron/monitor. Set the same value in Vercel.
# ---------------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------------
# App  (use your deployed URL in production, e.g. https://your-app.vercel.app)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
